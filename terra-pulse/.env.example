# Copy this file to .env and fill in your values
# .env is gitignored — never commit your real secrets

# WorldNews API — get a free key at https://worldnewsapi.com
WORLDNEWS_API_KEY=your_worldnews_api_key_here

# PostgreSQL (optional — defaults work for local dev)
POSTGRES_DB=terrapulse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
